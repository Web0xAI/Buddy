# MINIMAX_API_KEY: Required for MiniMax API calls.
MINIMAX_API_KEY="MY_MINIMAX_API_KEY"

# Optional: MiniMax API Configuration (Defaults to International API)
# For International API: "https://api.minimaxi.chat/v1" (Default)
# For Domestic API: "https://api.minimax.io/v1"
MINIMAX_BASE_URL="https://api.minimaxi.chat/v1"

# Optional: MiniMax model to use (Defaults to minimax-m2.7)
MINIMAX_MODEL="minimax-m2.7"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
